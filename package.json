{
  "name": "sarmaye-man",
  "version": "1.0.0",
  "description": "Persian local-first PWA for tracking assets, live prices, and profit/loss.",
  "license": "BSD-3-Clause",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "build:android-web": "vite build --config vite.android.config.ts",
    "build:tgju-service": "esbuild server/tgju-service.ts --bundle --platform=node --target=node22 --format=esm --outfile=build/tgju-service.mjs",
    "android:sync": "cap sync android",
    "start": "vinext start",
    "test": "npm run build && node --import tsx --test tests/rendered-html.test.mjs tests/portfolio.test.mjs tests/tgju.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern dist-android --ignore-pattern .next --ignore-pattern android/app/src/main/assets --ignore-pattern android/app/build"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.4"
  },
  "type": "module"
}
